
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Educated Wish</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.min.js"></script>
</head>
<body>

<header>
    <h1>Educated Wish</h1>
    <div class="header-content">
        <div class="user-controls">
            <button onclick="setUsername()">Set Username</button>
            <button onclick="clearUsername()">Clear Username</button>
            <div id="userDisplay"></div>
        </div>
        <div class="navigation">
            <button onclick="showSection('main')">Home</button>
            <button onclick="showSection('quotes')">Quotes & Strategies</button>
        </div>
        <div class="search-bar">
            <input type="text" id="searchInput" placeholder="Search for wishes..." onkeyup="searchPosts()">
        </div>
    </div>
    <div class="sort-options">
        <label for="sortSelect">Sort by:</label>
        <select id="sortSelect" onchange="sortPosts()">
            <option value="newest">Newest</option>
            <option value="oldest">Oldest</option>
            <option value="mostLiked">Most Liked</option>
            <option value="mostCommented">Most Commented</option>
        </select>
    </div>
</header>

<div id="mainSection" class="content">
    <div class="new-post-it-form">
        <input type="text" id="wishTitle" placeholder="Wish Title" maxlength="50" required>
        <textarea id="wishContent" placeholder="Describe your wish..." rows="4" maxlength="150" required></textarea>
        <label for="postColor">Choose a color:</label>
        <div class="color-picker" id="postColor">
            <div class="color-swatch" style="background-color: #FFF9C4;" data-color="#FFF9C4"></div>
            <div class="color-swatch" style="background-color: #FFCCBC;" data-color="#FFCCBC"></div>
            <div class="color-swatch" style="background-color: #C8E6C9;" data-color="#C8E6C9"></div>
            <div class="color-swatch" style="background-color: #BBDEFB;" data-color="#BBDEFB"></div>
            <div class="color-swatch" style="background-color: #E1BEE7;" data-color="#E1BEE7"></div>
        </div>
        <button onclick="createPostIt()">Post Your Wish</button>
    </div>

    <div class="main-content">
        <div class="post-it-container" id="postItContainer">
            <!-- Post-it notes will be appended here dynamically -->
        </div>
        <div class="right-section">
            <div class="highlighted-posts">
                <h3>Top Posts</h3>
                <div id="topPostsContainer">
                    <!-- Top posts will be appended here dynamically -->
                </div>
            </div>
            <div class="common-themes">
                <h3>What do people wish for most?</h3>
                <div id="commonThemesContainer">
                    <!-- Common themes will be appended here dynamically -->
                </div>
            </div>
        </div>
    </div>
</div>

<div id="quotesSection" class="content" style="display:none;">
    <div class="content-container" id="contentContainer">
        <!-- Quotes, strategies, and novel graphics will be appended here dynamically -->
    </div>
</div>

<!-- The Modal -->
<div id="commentModal" class="modal">
    <div class="modal-content">
        <span class="close-button" onclick="closeModal()">&times;</span>
        <div id="modalPostContent"></div>
        <div class="comment-section">
            <div class="comment-form">
                <input class="comment-input" placeholder="Add a comment...">
                <button class="comment-button" onclick="addModalComment()">Submit</button>
            </div>
            <div id="modalCommentsContainer"></div>
        </div>
    </div>
</div>

<!-- Edit Color Modal -->
<div id="editColorModal" class="modal">
    <div class="modal-content">
        <span class="close-button" onclick="closeEditColorModal()">&times;</span>
        <div class="color-picker" id="editPostColor">
            <div class="color-swatch" style="background-color: #FFF9C4;" data-color="#FFF9C4"></div>
            <div class="color-swatch" style="background-color: #FFCCBC;" data-color="#FFCCBC"></div>
            <div class="color-swatch" style="background-color: #C8E6C9;" data-color="#C8E6C9"></div>
            <div class="color-swatch" style="background-color: #BBDEFB;" data-color="#BBDEFB"></div>
            <div class="color-swatch" style="background-color: #E1BEE7;" data-color="#E1BEE7"></div>
        </div>
        <button class="comment-button" onclick="applyColorChange()">Apply Color</button>
    </div>
</div>

<script src="scripts.js"></script>
</body>
</html>
